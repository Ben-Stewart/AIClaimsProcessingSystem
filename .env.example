# ─────────────────────────────────────────────
# Database
# Recommended: Neon (free tier) → https://neon.tech
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct (non-pooler) connection — required for Prisma migrations (advisory locks)
DIRECT_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# ─────────────────────────────────────────────
# Redis
# Recommended: Upstash (free tier) → https://upstash.com
# Use rediss:// (TLS) for Upstash
# ─────────────────────────────────────────────
REDIS_URL="rediss://default:password@host:6379"

# ─────────────────────────────────────────────
# File Storage (Cloudflare R2)
# Create a bucket at → https://dash.cloudflare.com
# ─────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET_NAME="claims-documents"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ─────────────────────────────────────────────
# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET="minimum-32-character-random-secret"
JWT_REFRESH_SECRET="minimum-32-character-random-secret"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────
# AI Services
# ─────────────────────────────────────────────

# OpenAI → https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# Azure AI Document Intelligence → https://portal.azure.com (optional)
AZURE_DI_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_DI_KEY="your-azure-di-key"

# ─────────────────────────────────────────────
# App (API service)
# ─────────────────────────────────────────────
NODE_ENV="production"
API_PORT=3001
API_URL="https://your-api.railway.app"
CORS_ORIGIN="https://your-web.railway.app"
AUTO_APPROVE_THRESHOLD=5000

# ─────────────────────────────────────────────
# App (Worker service)
# ─────────────────────────────────────────────
# NODE_ENV, DATABASE_URL, REDIS_URL, OPENAI_API_KEY, R2_*, AZURE_DI_* (same as API)
API_URL="https://your-api.railway.app"

# ─────────────────────────────────────────────
# Frontend (Web service — Vite bakes these in at build time)
# Must be set BEFORE the first Railway build of the web service
# ─────────────────────────────────────────────
VITE_API_URL="https://your-api.railway.app"
VITE_WS_URL="https://your-api.railway.app"
