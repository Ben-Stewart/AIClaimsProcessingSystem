{
  "name": "ai-claims-processing-system",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter=./apps/* --filter=@claims/shared run dev",
    "build": "pnpm --filter=@claims/shared build && pnpm --parallel --filter=./apps/* run build",
    "lint": "pnpm --recursive run lint",
    "test": "pnpm --recursive run test",
    "db:generate": "pnpm --filter=@claims/api run db:generate",
    "db:migrate": "pnpm --filter=@claims/api run db:migrate",
    "db:seed": "pnpm --filter=@claims/api run db:seed",
    "db:studio": "pnpm --filter=@claims/api run db:studio"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
