{
  "name": "@claims/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file ../../.env src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:generate:ci": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env -- tsx src/db/seeds/demo.seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "lint": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest"
  },
  "dependencies": {
    "@claims/shared": "workspace:*",
    "@azure/ai-form-recognizer": "^4.0.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^5.16.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.5",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.52.7",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "socket.io": "^4.7.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.11",
    "dotenv-cli": "^7.4.2",
    "jest": "^29.7.0",
    "prisma": "^5.16.1",
    "ts-jest": "^29.2.0",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}
